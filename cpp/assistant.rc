// ONE Win32 DIALOGEX resource used on all three platforms.
//   Windows : compiled directly by rc.exe (embed-resource, from build.rs).
//   mac/linux: `php WDL/swell/swell_resgen.php assistant.rc` -> assistant.rc_mac_dlg,
//              which is #included from a .cpp that first #includes swell-dlggen.h.
//
// Keep this file ASCII-only: rc.exe interprets non-ASCII per the build codepage,
// which mangles umlauts/ss. Dynamic (Rust-supplied) strings carry the real
// German text at runtime.
#ifdef _WIN32
#include <windows.h>
#endif
#include "resource.h"

ID_ASSISTANT_DLG DIALOGEX 0, 0, 400, 300
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
CAPTION "ReaLackey"
FONT 8, "MS Shell Dlg"
BEGIN
    EDITTEXT        ID_OUTPUT_EDIT, 6, 6, 388, 240,
                    ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT           "Ready.", ID_STATUS_TEXT, 6, 250, 388, 9, SS_LEFTNOWORDWRAP
    EDITTEXT        ID_INPUT_EDIT, 6, 262, 322, 14,
                    ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    DEFPUSHBUTTON   "&Send", ID_SUBMIT_BTN, 334, 262, 60, 14
    PUSHBUTTON      "&Close", IDCANCEL, 334, 280, 60, 14
END

ID_PROVIDERS_DLG DIALOGEX 0, 0, 340, 176
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "AI Providers"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Configured providers. The default (*) drives the conversation.", -1, 6, 6, 328, 9, SS_LEFTNOWORDWRAP
    LISTBOX         ID_PROV_LIST, 6, 18, 328, 116,
                    LBS_NOTIFY | LBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON      "&Add...", ID_PROV_ADD, 6, 140, 54, 16
    PUSHBUTTON      "&Edit...", ID_PROV_EDIT, 64, 140, 54, 16
    PUSHBUTTON      "De&lete", ID_PROV_DELETE, 122, 140, 54, 16
    PUSHBUTTON      "Set De&fault", ID_PROV_DEFAULT, 180, 140, 74, 16
    DEFPUSHBUTTON   "&Close", IDCANCEL, 280, 140, 54, 16
END

ID_PROVIDER_EDIT_DLG DIALOGEX 0, 0, 300, 218
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Provider settings"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "&Name:", -1, 6, 9, 58, 9
    EDITTEXT        ID_PE_LABEL, 66, 6, 228, 12, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT           "Base &URL:", ID_PE_BASEURL_LBL, 6, 27, 58, 9
    EDITTEXT        ID_PE_BASEURL, 66, 24, 228, 12, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT           "&Model:", -1, 6, 45, 58, 9
    EDITTEXT        ID_PE_MODEL, 66, 42, 170, 12, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON      "&Fetch models...", ID_PE_FETCH, 240, 42, 54, 13
    LTEXT           "Max &tokens:", -1, 6, 63, 58, 9
    EDITTEXT        ID_PE_MAXTOK, 66, 60, 60, 12, ES_AUTOHSCROLL | ES_NUMBER | WS_TABSTOP | WS_BORDER
    LTEXT           "Tool &steps:", -1, 138, 63, 48, 9
    EDITTEXT        ID_PE_MAXTURNS, 190, 60, 44, 12, ES_AUTOHSCROLL | ES_NUMBER | WS_TABSTOP | WS_BORDER
    AUTOCHECKBOX    "Supports &images (vision)", ID_PE_VISION, 66, 78, 160, 10, WS_TABSTOP
    LTEXT           "API keys - the top key is used; on a limit it falls back to the next:", -1, 6, 96, 288, 9
    LTEXT           "Add ke&y:", -1, 6, 111, 58, 9
    EDITTEXT        ID_PE_KEY, 66, 108, 170, 12, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON      "&Add", ID_PE_KEYADD, 240, 108, 54, 13
    LTEXT           "Configured &keys:", -1, 6, 126, 58, 9
    LISTBOX         ID_PE_KEYLIST, 66, 123, 170, 54, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON      "&Delete", ID_PE_KEYDEL, 240, 123, 54, 13
    PUSHBUTTON      "Move u&p", ID_PE_KEYUP, 240, 140, 54, 13
    PUSHBUTTON      "Move do&wn", ID_PE_KEYDOWN, 240, 157, 54, 13
    LTEXT           "", ID_PE_KEYHINT, 66, 180, 228, 9, SS_LEFTNOWORDWRAP
    DEFPUSHBUTTON   "OK", IDOK, 186, 198, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 240, 198, 50, 14
END
